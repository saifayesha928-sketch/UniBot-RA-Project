# UniBot backend configuration.
# Copy this file to .env and fill in real values.
# All variables use the UNIBOT_ prefix. Do not commit your real .env.

## Database (PostgreSQL, Neon compatible)
# Two connection strings are required. Both must use the postgresql+psycopg
# driver and require SSL. The direct string targets the primary host. The
# pooled string targets a connection pooler host (its hostname contains
# "pooler").
UNIBOT_POSTGRES_DIRECT_DSN=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
UNIBOT_POSTGRES_POOLED_DSN=postgresql+psycopg://USER:PASSWORD@POOLER-HOST/DB?sslmode=require

## Vector store (Qdrant)
UNIBOT_QDRANT_URL=http://localhost:6333
UNIBOT_QDRANT_API_KEY=

## Environment and runtime mode
# development, test, or production
UNIBOT_ENVIRONMENT=development
# Optional override. Leave unset to derive from environment.
# local_smoke (fast, no API keys) or production_like (full quality).
# UNIBOT_RETRIEVAL_RUNTIME_MODE=production_like

## Backends for embeddings, reranking, and answering
# In production_like mode these default to Cohere and need the key below.
# In local_smoke mode they fall back to simple defaults with no keys needed.
# UNIBOT_EMBEDDING_DENSE_BACKEND=cohere       # hashing or cohere
# UNIBOT_EMBEDDING_SPARSE_BACKEND=fastembed   # hashing, token, or fastembed
# UNIBOT_RERANKER_BACKEND=cohere              # token_overlap, cohere, or cross_encoder
# UNIBOT_ANSWER_MODEL_BACKEND=openrouter      # deterministic, cohere, or openrouter
# UNIBOT_ANSWER_MODEL_FALLBACK_BACKEND=cohere # cohere or openrouter

# Cohere (embeddings, reranking, chat)
UNIBOT_COHERE_API_KEY=

# OpenRouter (answering model)
UNIBOT_OPENROUTER_API_KEY=
# Pick any model id offered by OpenRouter.
# UNIBOT_OPENROUTER_MODEL=<provider/model-id>

## Grounding check
# passthrough (no check) or lettucedetect (local model, see README for weights)
# UNIBOT_GROUNDING_VERIFIER_BACKEND=lettucedetect
# UNIBOT_GROUNDING_MODEL=models/tinylettuce-ettin-68m-en

## Query understanding (optional)
# keyword or semantic
UNIBOT_QUERY_CLASSIFIER_BACKEND=semantic
# UNIBOT_QUERY_REWRITER_ENABLED=false
# UNIBOT_CONTEXTUAL_RETRIEVAL_ENABLED=false

## Admin API
# Required to call the /admin endpoints. Set a long random value.
UNIBOT_ADMIN_API_KEY=

## Raw document storage (optional, for document_asset ingestion)
# local or object_store
UNIBOT_RAW_STORAGE_BACKEND=local
# UNIBOT_RAW_OBJECT_STORE_BUCKET=
# UNIBOT_RAW_OBJECT_STORE_ENDPOINT_URL=
# UNIBOT_RAW_OBJECT_STORE_REGION=
